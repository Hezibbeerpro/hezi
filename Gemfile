source "https://rubygems.org"

# שימוש בגרסה מודרנית של Jekyll
gem "jekyll", "~> 4.3"

# תוספים פופולריים בגרסאות שתומכות ב-Ruby החדש
group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-gist"
end

# הכרחי להרצת שרת ב-Windows וב-Ruby 4
gem "webrick"